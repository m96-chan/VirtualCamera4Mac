# Local one-time signing setup for Developer ID distribution.
#
# This does NOT build or release — CI (release.yml) does that. It provisions the
# Apple assets a Developer ID + notarized release needs:
#   - the two App IDs (Bundle IDs), with App Groups + System Extension capability,
#   - Developer ID provisioning profiles for both targets (macOS).
#
# Auth uses an App Store Connect API key via Spaceship::ConnectAPI (the `produce`
# tool does not support API-key auth and is intentionally avoided). Run locally:
#   ASC_KEY_ID=... ASC_ISSUER_ID=... \
#   ASC_KEY_P8_BASE64="$(base64 -i AuthKey_XXXX.p8)" \
#     fastlane mac setup_signing
#
# Generated profiles land in build/profiles/ (git-ignored); base64-encode them
# into GitHub secrets per docs/ci-signing.md.

require "spaceship"
require "fileutils"
require "base64"
require "tmpdir"

APP_ID           = "io.github.m96chan.VirtualCamera4Mac".freeze
EXT_ID           = "io.github.m96chan.VirtualCamera4Mac.Extension".freeze
TEAM_ID          = "9U26G7YWJ9".freeze
# Stable profile names so re-runs reuse the same profiles (no timestamped dupes).
# These must match the PROVISIONING_PROFILE_NAME_* GitHub secrets.
APP_PROFILE_NAME = "VirtualCamera4Mac Developer ID".freeze
EXT_PROFILE_NAME = "VirtualCamera4Mac Extension Developer ID".freeze
PROFILE_DIR      = File.expand_path("../build/profiles", __dir__).freeze

# Path to the .p8 API key. Prefer SPACESHIP_CONNECT_API_KEY_FILEPATH; otherwise
# materialize it from the base64 in ASC_KEY_P8_BASE64.
def api_key_filepath
  existing = ENV["SPACESHIP_CONNECT_API_KEY_FILEPATH"]
  return existing if existing && File.exist?(existing)
  path = File.join(Dir.tmpdir, "asc_authkey.p8")
  File.write(path, Base64.decode64(ENV.fetch("ASC_KEY_P8_BASE64")))
  path
end

def connect_api!
  # This team is a standard (non-Enterprise) team; the API can't infer it, and
  # sigh reads this from the environment.
  ENV["SPACESHIP_CONNECT_API_IN_HOUSE"] ||= "false"
  token = Spaceship::ConnectAPI::Token.create(
    key_id: ENV.fetch("ASC_KEY_ID"),
    issuer_id: ENV.fetch("ASC_ISSUER_ID"),
    filepath: api_key_filepath,
    in_house: false
  )
  Spaceship::ConnectAPI.token = token
end

def ensure_bundle_id(identifier, name)
  existing = Spaceship::ConnectAPI::BundleId.all.find { |b| b.identifier == identifier }
  if existing
    UI.message("Bundle ID already exists: #{identifier}")
    return existing
  end
  UI.message("Creating Bundle ID: #{identifier}")
  Spaceship::ConnectAPI::BundleId.create(
    name: name,
    identifier: identifier,
    platform: Spaceship::ConnectAPI::BundleIdPlatform::MAC_OS,
    seed_id: TEAM_ID
  )
end

def ensure_capability(bundle_id, type)
  bundle_id.create_capability(type)
  UI.success("Enabled #{type} on #{bundle_id.identifier}")
rescue => e
  # Already-enabled writes surface as errors; treat as non-fatal but report.
  UI.important("Capability #{type} on #{bundle_id.identifier}: #{e.message}")
end

platform :mac do
  desc "Create/refresh Developer ID signing assets (Bundle IDs, capabilities, profiles)"
  lane :setup_signing do
    connect_api!
    cap = Spaceship::ConnectAPI::BundleIdCapability::Type

    app_bundle = ensure_bundle_id(APP_ID, "VirtualCamera4Mac")
    ext_bundle = ensure_bundle_id(EXT_ID, "VirtualCamera4Mac Extension")

    ensure_capability(app_bundle, cap::APP_GROUPS)
    ensure_capability(app_bundle, cap::SYSTEM_EXTENSION_INSTALL)
    ensure_capability(ext_bundle, cap::APP_GROUPS)

    FileUtils.mkdir_p(PROFILE_DIR)
    get_provisioning_profile(platform: "macos", developer_id: true,
                             app_identifier: APP_ID, provisioning_name: APP_PROFILE_NAME,
                             ignore_profiles_with_different_name: true, output_path: PROFILE_DIR)
    get_provisioning_profile(platform: "macos", developer_id: true,
                             app_identifier: EXT_ID, provisioning_name: EXT_PROFILE_NAME,
                             ignore_profiles_with_different_name: true, output_path: PROFILE_DIR)

    UI.success("Signing assets ready. Profiles in #{PROFILE_DIR}")
    UI.message("Next: base64-encode the profiles + your Developer ID .p12 into GitHub secrets (docs/ci-signing.md).")
  end
end
